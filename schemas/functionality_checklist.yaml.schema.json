{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Functionality Checklist Schema",
  "type": "object",
  "required": ["modules", "overall_reliability"],
  "properties": {
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "status", "reliability", "test_coverage", "test_method", "error_handling"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "name_en": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["complete", "partial", "not_started"] },
          "reliability": { "type": "number", "minimum": 0, "maximum": 100 },
          "test_coverage": { "type": "number", "minimum": 0, "maximum": 100 },
          "test_method": { "type": "string" },
          "error_handling": { "type": "boolean" }
        }
      }
    },
    "overall_reliability": { "type": "number", "minimum": 0, "maximum": 100 }
  }
}
