{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Maintainability Schema",
  "type": "object",
  "required": ["code_complexity", "documentation_completeness", "technical_debt", "iteration_plan"],
  "properties": {
    "code_complexity": {
      "type": "string",
      "enum": ["low", "medium", "high", "very_high"]
    },
    "documentation_completeness": {
      "type": "string",
      "enum": ["complete", "basic", "partial", "none"]
    },
    "technical_debt": {
      "type": "object",
      "required": ["level"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["none", "low", "medium", "high", "very_high"]
        },
        "description": { "type": "string" },
        "repaymentPlan": { "type": "string" }
      }
    },
    "iteration_plan": {
      "type": "object",
      "required": ["has_plan"],
      "properties": {
        "has_plan": { "type": "boolean" },
        "next_milestone": { "type": "string" },
        "date": { "type": "string", "format": "date" }
      }
    },
    "code_quality": {
      "type": "object",
      "properties": {
        "cyclomatic_complexity": { "type": "number" },
        "lines_of_code": { "type": "number" },
        "test_coverage": { "type": "number", "minimum": 0, "maximum": 100 },
        "duplicate_rate": { "type": "number" }
      }
    }
  }
}
