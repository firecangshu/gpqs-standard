{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Domain Knowledge Schema",
  "type": "object",
  "required": ["domain", "knowledge_items"],
  "properties": {
    "domain": {
      "type": "string",
      "description": "领域名称（中文）/ Domain name (Chinese)"
    },
    "domain_en": {
      "type": "string",
      "description": "领域名称（英文）/ Domain name (English)"
    },
    "knowledge_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "statement", "source", "source_type", "practicality", "reusability", "how_it_changes_behavior", "evidence"],
        "properties": {
          "id": {
            "type": "string",
            "description": "知识 ID（唯一）/ Knowledge ID (unique)"
          },
          "statement": {
            "type": "string",
            "description": "知识陈述（中文）/ Knowledge statement (Chinese)"
          },
          "statement_en": {
            "type": "string",
            "description": "知识陈述（英文）/ Knowledge statement (English)"
          },
          "source": {
            "type": "string",
            "description": "来源 / Source"
          },
          "source_type": {
            "type": "string",
            "enum": ["official_doc", "expert_opinion", "data_analysis", "case_study", "other"],
            "description": "来源类型 / Source type"
          },
          "practicality": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "实操性 / Practicality"
          },
          "reusability": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "可复用性 / Reusability"
          },
          "how_it_changes_behavior": {
            "type": "string",
            "description": "如何改变项目行为（中文）/ How it changes project behavior (Chinese)"
          },
          "how_it_changes_behavior_en": {
            "type": "string",
            "description": "如何改变项目行为（英文）/ How it changes project behavior (English)"
          },
          "evidence": {
            "type": "object",
            "required": ["level", "description"],
            "properties": {
              "level": {
                "type": "string",
                "enum": ["V0", "V1", "V2", "V3", "V4", "V5"],
                "description": "证据等级 / Evidence level"
              },
              "description": {
                "type": "string",
                "description": "证据描述（中文）/ Evidence description (Chinese)"
              },
              "description_en": {
                "type": "string",
                "description": "证据描述（英文）/ Evidence description (English)"
              }
            }
          }
        }
      }
    },
    "expert_experience": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "description_en": {
            "type": "string"
          },
          "expert_name": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "amplify_expert": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "description_en": {
          "type": "string"
        }
      }
    }
  }
}