{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Security Checklist Schema",
  "type": "object",
  "required": ["items", "overall_security_score"],
  "properties": {
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "status", "risk_level"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "name_en": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["passed", "failed", "not_checked"] },
          "risk_level": { "type": "string", "enum": ["high", "medium", "low"] },
          "mitigation": { "type": "string" }
        }
      }
    },
    "overall_security_score": { "type": "number", "minimum": 0, "maximum": 100 }
  }
}
